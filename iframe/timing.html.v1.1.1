<!doctype html>
<html lang="zh-Hans">
<head>
    <title>时序图分析</title>
    <meta charset="utf-8" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { 
            display: flex; 
            height: 100vh; 
            background: #1e1e1e; 
            color: #fff; 
            font-family: Consolas, monospace; 
            overflow: hidden;
        }
        .left-panel {
            width: 320px;
            min-width: 320px;
            padding: 15px;
            border-right: 1px solid #444;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }
        .right-panel {
            flex: 1;
            padding: 15px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            position: relative;
        }
        h2 { color: #ffcc00; margin-bottom: 12px; font-size: 18px; }
        h3 { color: #aaa; margin: 12px 0 8px; font-size: 13px; border-bottom: 1px solid #444; padding-bottom: 4px; }
        .info { color: #fff; font-size: 12px; margin-bottom: 12px; line-height: 1.5; white-space: pre-line; }
        .form-group { margin-bottom: 12px; }
        label { display: block; color: #aaa; font-size: 12px; margin-bottom: 4px; }
        select, input { 
            width: 100%; 
            padding: 8px 12px; 
            background: #2d2d2d; 
            border: 1px solid #555; 
            border-radius: 4px; 
            color: #fff; 
            font-family: Consolas, monospace; 
            font-size: 14px; 
        }
        input[type="checkbox"] {
            width: auto;
            margin-right: 8px;
            vertical-align: middle;
        }
        select:focus, input:focus { outline: none; border-color: #00aaff; }
        .btn-group { display: flex; gap: 8px; margin-top: 15px; }
        .btn { 
            padding: 10px 20px; 
            border: none; 
            border-radius: 4px; 
            font-family: Consolas, monospace; 
            font-size: 14px; 
            cursor: pointer; 
            flex: 1;
        }
        .btn-primary { background: #00aaff; color: #fff; }
        .btn-primary:hover { background: #0088cc; }
        .btn-export { background: #28a745; color: #fff; }
        .btn-export:hover { background: #218838; }
        .btn-cancel { background: #555; color: #fff; }
        .btn-cancel:hover { background: #444; }
        
        .net-list {
            max-height: 300px;
            overflow-y: auto;
            background: #252525;
            border: 1px solid #444;
            border-radius: 4px;
            padding: 8px;
        }
        .net-item {
            display: flex;
            align-items: center;
            padding: 4px 8px;
            cursor: pointer;
            border-radius: 3px;
            font-size: 12px;
        }
        .net-item:hover { background: #333; }
        .net-item.selected { background: #00aaff30; border-left: 3px solid #00aaff; }
        .net-item.select-all { font-weight: bold; color: #0af; }
        .net-item input[type="checkbox"] { width: auto; margin-right: 8px; }
        .select-all-row { display: flex; align-items: center; padding-bottom: 8px; border-bottom: 1px solid #444; margin-bottom: 4px; }
        .select-all-row input[type="checkbox"] { width: auto; margin-right: 8px; }
        .select-all-row .search-box { flex: 1; margin-left: 10px; }
        .search-box input { 
            width: 100%; 
            padding: 4px 8px; 
            background: #252525; 
            border: 1px solid #444; 
            border-radius: 3px; 
            color: #fff; 
            font-family: Consolas, monospace; 
            font-size: 12px; 
        }
        .search-box input:focus { outline: none; border-color: #00aaff; }
        .search-box input::placeholder { color: #666; }
        
        .result-info {
            padding: 12px;
            background: #2a2a2a;
            border-radius: 4px;
            white-space: pre-line;
            line-height: 1.5;
            font-size: 12px;
            margin-bottom: 12px;
            max-height: 120px;
            overflow-y: auto;
            position: relative;
        }
        
        .copy-btn {
            position: absolute;
            top: 8px;
            right: 8px;
            background: #3a3a3a;
            border: 1px solid #555;
            border-radius: 3px;
            color: #aaa;
            font-size: 11px;
            padding: 4px 8px;
            cursor: pointer;
        }
        .copy-btn:hover { background: #4a4a4a; color: #fff; }
        
        .svg-container {
            flex: 1;
            background: #2d2d2d;
            border-radius: 8px;
            padding: 10px;
            overflow: auto;
            position: relative;
            cursor: grab;
        }
        .svg-container:active { cursor: grabbing; }
        
        .svg-wrapper {
            display: flex;
            flex-direction: column;
            min-height: 100%;
        }
        
        .svg-main {
            display: flex;
            flex: 1;
        }
        
        .net-labels {
            width: 70px;
            min-width: 70px;
            background: #2d2d2d;
            border-right: 1px solid #444;
            display: flex;
            flex-direction: column;
        }
        
        .timing-header {
            height: 60px;
            min-height: 60px;
            padding: 10px;
            border-bottom: 1px solid #444;
            text-align: center;
        }
        
        .timing-header .title {
            color: #fff;
            font-family: Consolas, monospace;
            font-size: 14px;
            font-weight: bold;
            margin-bottom: 4px;
        }
        
        .timing-header .subtitle {
            color: #fff;
            font-family: Consolas, monospace;
            font-size: 11px;
        }
        
        .net-label {
            height: 60px;
            display: flex;
            align-items: center;
            padding-left: 8px;
            font-family: Consolas, monospace;
            font-size: 11px;
            color: #fff;
        }
        
        .net-label {
            height: 60px;
            display: flex;
            align-items: center;
            padding-left: 8px;
            font-family: Consolas, monospace;
            font-size: 11px;
            color: #fff;
        }
        
        .net-label-in {
            height: 60px;
            display: flex;
            align-items: center;
            padding-left: 8px;
            font-family: Consolas, monospace;
            font-size: 10px;
            color: #666;
        }
        
        .timing-svg-wrapper {
            position: relative;
            overflow: hidden;
        }
        
        .zoom-controls {
            position: absolute;
            bottom: 15px;
            right: 30px;
            display: flex;
            gap: 5px;
            z-index: 10;
        }
        .zoom-btn {
            width: 32px;
            height: 32px;
            background: #3a3a3a;
            border: 1px solid #555;
            border-radius: 4px;
            color: #fff;
            font-size: 18px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .zoom-btn:hover { background: #4a4a4a; }
        
        .param-row { display: flex; gap: 8px; }
        .param-row .form-group { flex: 1; }
    </style>
</head>
<body>
    <div class="left-panel">
        <div class="info" id="compInfo">正在加载数据...</div>
        
        <h3>选择网络（可多选）</h3>
        <div class="net-list" id="netList">
            <div style="color:#888;font-size:12px;padding:8px;">加载中...</div>
        </div>
        
        <div class="param-row">
            <div class="form-group">
                <label>时钟频率 (MHz)</label>
                <input type="number" id="freqInput" value="100" min="1" max="1000" step="1">
            </div>
            <div class="form-group">
                <label>周期 (ns)</label>
                <input type="number" id="periodInput" value="10" readonly style="background:#222;color:#888;">
            </div>
        </div>
        
        <div class="param-row">
            <div class="form-group">
                <label>建立时间 Tsu (ns)</label>
                <input type="number" id="setupInput" value="5" min="0" step="0.1">
            </div>
            <div class="form-group">
                <label>保持时间 Th (ns)</label>
                <input type="number" id="holdInput" value="2" min="0" step="0.1">
            </div>
        </div>
        
        <div class="btn-group">
            <button class="btn btn-primary" id="calcBtn">计算</button>
        </div>
        <div class="btn-group" style="margin-top:8px;">
            <button class="btn btn-export" id="exportBtn">导出SVG</button>
            <button class="btn btn-cancel" onclick="closeForm()">关闭</button>
        </div>
    </div>
    
    <div class="right-panel">
        <div class="result-info" id="resultText">
            <span id="resultContent">选择网络并设置参数后，点击计算查看结果</span>
            <button class="copy-btn" onclick="copyResult()">复制</button>
        </div>
        <div class="svg-container" id="svgContainer">
            <div class="svg-wrapper" id="svgWrapper">
            <div class="timing-header" id="timingHeader">
                <div class="title"></div>
                <div class="subtitle"></div>
            </div>
            <div class="svg-main">
                <div class="net-labels" id="netLabels"></div>
                <div class="timing-svg-wrapper" id="timingSvgWrapper">
                    <div id="svgContent"></div>
                </div>
            </div>
        </div>
        </div>
            <div class="zoom-controls">
                <button class="zoom-btn" onclick="zoomIn()">+</button>
                <button class="zoom-btn" onclick="zoomOut()">-</button>
                <button class="zoom-btn" onclick="resetZoom()">⟲</button>
            </div>
    </div>
    
    <script>
        function log(msg) { 
            console.log('[Timing]', msg);
        }
        
        var componentData = null;
        var selectedNets = [];
        var autoUpdate = false;
        var computedData = null;
        var highlightedNets = [];
        
        var scaleX = 1;
        var translateX = 0;
        var isDragging = false;
        var startX;
        
        var svgContainer = document.getElementById('svgContainer');
        var svgContent = document.getElementById('svgContent');
        var timingSvgWrapper = document.getElementById('timingSvgWrapper');
        
        function updateTransform() {
            svgContent.style.transform = 'translate(' + translateX + 'px, 0px) scaleX(' + scaleX + ')';
        }
        
        function zoomIn() {
            scaleX *= 1.2;
            updateTransform();
        }
        
        function zoomOut() {
            scaleX /= 1.2;
            updateTransform();
        }
        
        function resetZoom() {
            scaleX = 1;
            translateX = 0;
            updateTransform();
        }
        
        svgContainer.addEventListener('wheel', function(e) {
            if (e.ctrlKey) {
                e.preventDefault();
                var rect = svgContainer.getBoundingClientRect();
                var mouseX = e.clientX - rect.left;
                // 以鼠标所在位置为缩放中心
                var contentX = (mouseX - translateX) / scaleX;
                var delta = e.deltaY > 0 ? 0.9 : 1.1;
                var newScale = scaleX * delta;
                translateX = mouseX - contentX * newScale;
                scaleX = newScale;
                updateTransform();
            } else if (e.shiftKey) {
                e.preventDefault();
                translateX -= e.deltaY;
                updateTransform();
            }
        });
        
        svgContainer.addEventListener('mousedown', function(e) {
            if (e.target.classList.contains('zoom-btn')) return;
            isDragging = true;
            startX = e.clientX - translateX;
            svgContainer.style.cursor = 'grabbing';
        });
        
        document.addEventListener('mousemove', function(e) {
            if (!isDragging) return;
            translateX = e.clientX - startX;
            updateTransform();
        });
        
        document.addEventListener('mouseup', function() {
            isDragging = false;
            svgContainer.style.cursor = 'grab';
        });
        
        var powerNets = ['GND', '3V3', '5V', 'VCC', 'VDD', 'AVDD', 'DVDD', 'AGND', 'DGND', 'VSS', '12V', '24V', '1V8', '2V5', '1V2', '1V5', '1V0'];
        
        function initForm(data) {
            if (!data) return;
            componentData = data;
            log('表单初始化成功');
            document.getElementById('compInfo').textContent = data.info;
            
            var netList = document.getElementById('netList');
            netList.innerHTML = '';
            
            var selectAllRow = document.createElement('div');
            selectAllRow.className = 'select-all-row';
            selectAllRow.innerHTML = '<input type="checkbox" id="selectAll"> <span>全选</span>';
            netList.appendChild(selectAllRow);
            
            var searchBox = document.createElement('div');
            searchBox.className = 'search-box';
            searchBox.innerHTML = '<input type="text" id="netSearch" placeholder="搜索网络...">';
            selectAllRow.appendChild(searchBox);
            
            var selectAllCheckbox = document.getElementById('selectAll');
            selectAllCheckbox.addEventListener('change', function() {
                var allItems = netList.querySelectorAll('.net-item:not(.select-all)');
                var netCheckboxes = netList.querySelectorAll('.net-item:not(.select-all) input');
                if (this.checked) {
                    selectedNets = [];
                    highlightedNets = [];
                    allItems.forEach(function(item) {
                        item.classList.add('selected');
                        var net = item.dataset.net;
                        var origIdx = parseInt(item.dataset.index, 10);
                        selectedNets.push(origIdx);
                        highlightedNets.push(net);
                        var cb = item.querySelector('input');
                        if (cb) cb.checked = true;
                        try { eda.pcb_Net.highlightNet(net); } catch {}
                    });
                } else {
                    allItems.forEach(function(item) {
                        item.classList.remove('selected');
                        var net = item.dataset.net;
                        var cb = item.querySelector('input');
                        if (cb) cb.checked = false;
                        try { eda.pcb_Net.unhighlightNet(net); } catch {}
                    });
                    selectedNets = [];
                    highlightedNets = [];
                }
                log('全选: ' + this.checked + ', 选中: ' + selectedNets.length);
                computeTimingData();
            });
            
            for (let i = 0; i < (data.commonNets || []).length; i++) {
                let netInfo = data.commonNets[i];
                let netName = netInfo.net;
                let netUpper = String(netName).toUpperCase();
                let isPowerNet = powerNets.some(function(pn) { 
                    return netUpper === pn || netUpper.startsWith(pn + '_') || netUpper.endsWith('_' + pn); 
                });
                if (isPowerNet) continue;
                
                let div = document.createElement('div');
                div.className = 'net-item';
                div.dataset.index = i;
                div.dataset.net = netName;
                div.innerHTML = '<input type="checkbox" value="' + i + '"> ' + 
                    (data.nets[i] || netInfo.net);
                
                let checkbox = div.querySelector('input');
                let itemDiv = div;
                let currentIndex = i;
                
                // 添加鼠标悬停临时高亮功能
                // 使用立即执行函数表达式(IIFE)来捕获当前的netName值
                (function(currentNetName) {
                    itemDiv.addEventListener('mouseenter', function() {
                        // 只对未选中的网络应用临时高亮
                        var index = parseInt(this.dataset.index, 10);
                        if (selectedNets.indexOf(index) === -1) {
                            try { 
                                eda.pcb_Net.highlightNet(currentNetName); 
                            } catch (e) {
                                // 忽略高亮错误，避免频繁事件导致的问题
                            }
                        }
                    });
                    
                    itemDiv.addEventListener('mouseleave', function() {
                        // 只对未选中的网络取消临时高亮
                        var index = parseInt(this.dataset.index, 10);
                        if (selectedNets.indexOf(index) === -1) {
                            try { 
                                eda.pcb_Net.unhighlightNet(currentNetName); 
                            } catch (e) {
                                // 忽略取消高亮错误
                            }
                        }
                    });
                })(netName);
                
                itemDiv.addEventListener('click', (function(idx, el, cb) {
                    return function(e) {
                        if (e.target !== cb) {
                            cb.checked = !cb.checked;
                        }
                        cb.dispatchEvent(new Event('change'));
                    };
                })(currentIndex, itemDiv, checkbox));
                checkbox.addEventListener('change', (function(index, el) {
                    return function() {
                        var net = el.dataset.net;
                        if (this.checked) {
                            el.classList.add('selected');
                            if (selectedNets.indexOf(index) === -1) selectedNets.push(index);
                            try { eda.pcb_Net.highlightNet(net); } catch {}
                            if (highlightedNets.indexOf(net) === -1) highlightedNets.push(net);
                        } else {
                            el.classList.remove('selected');
                            selectedNets = selectedNets.filter(function(n) { return n !== index; });
                            try { eda.pcb_Net.unhighlightNet(net); } catch {}
                            highlightedNets = highlightedNets.filter(function(n) { return n !== net; });
                        }
                        var selectAllBox = document.getElementById('selectAll');
                        if (selectAllBox && !this.checked && selectAllBox.checked) {
                            var netItems = document.querySelectorAll('.net-item:not(.select-all) input');
                            var allChecked = Array.from(netItems).every(function(cb) { return cb.checked; });
                            if (!allChecked) selectAllBox.checked = false;
                        }
                        log('选中网络: ' + selectedNets.length + ' [' + selectedNets.join(',') + ']');
                        computeTimingData();
                    };
                })(i, itemDiv));
                
                netList.appendChild(div);
            }
            
            if (data.commonNets.length > 0) {
                var allItems = netList.querySelectorAll('.net-item:not(.select-all)');
                if (allItems.length > 0) {
                    var firstItem = allItems[0];
                    var firstCheck = firstItem.querySelector('input');
                    var firstOrigIdx = parseInt(firstItem.dataset.index, 10);
                    if (firstCheck) {
                        firstCheck.checked = true;
                        selectedNets = [firstOrigIdx];
                        firstItem.classList.add('selected');
                        var firstNet = firstItem.dataset.net;
                        try { eda.pcb_Net.highlightNet(firstNet); } catch {}
                        highlightedNets = [firstNet];
                    }
                }
            }
            
            updatePeriod();
            if (selectedNets.length > 0) {
                computeTimingData();
            }
            
            document.getElementById('netSearch').addEventListener('input', function() {
                var searchText = this.value.toLowerCase();
                var allItems = netList.querySelectorAll('.net-item:not(.select-all)');
                allItems.forEach(function(item) {
                    var netName = item.dataset.net.toLowerCase();
                    if (searchText === '' || netName.indexOf(searchText) !== -1) {
                        item.style.display = 'flex';
                    } else {
                        item.style.display = 'none';
                    }
                });
            });
        }
        
        function updatePeriod() {
            var freq = parseFloat(document.getElementById('freqInput').value) || 100;
            var period = 1000 / freq;
            document.getElementById('periodInput').value = period.toFixed(2);
        }
        
        function calculate() {
            computedData = computeTimingData();
            updateDisplay();
        }
        
        function computeTimingData() {
            if (!componentData || selectedNets.length === 0) {
                return null;
            }
            
            var freq = parseFloat(document.getElementById('freqInput').value);
            var setup = parseFloat(document.getElementById('setupInput').value);
            var hold = parseFloat(document.getElementById('holdInput').value);
            
            if (isNaN(freq) || freq <= 0) {
                log('频率无效');
                return null;
            }
            
            var period = 1000 / freq;
            var dist = Math.abs(componentData.x2 - componentData.x1) + Math.abs(componentData.y2 - componentData.y1);
            
            var signals = selectedNets.map(function(idx) {
                var net = componentData.commonNets[idx];
                if (!net) return null;
                
                var traceLen = (componentData.netLengths && componentData.netLengths[net.net]) 
                    ? componentData.netLengths[net.net] : null;
                var useLen = traceLen !== null ? traceLen : dist;
                var pd = useLen * 0.0254 / 152.4;
                var margin = period - (setup + hold + pd);
                
                return {
                    net: net.net,
                    sourcePin: net.sourcePin,
                    targetPin: net.targetPin,
                    pd: pd,
                    margin: margin,
                    dist: dist,
                    traceLen: traceLen
                };
            }).filter(function(s) { return s !== null; });
            
            if (signals.length === 0) {
                log('无有效信号');
                return null;
            }
            
            return {
                freq: freq,
                period: period,
                setup: setup,
                hold: hold,
                dist: dist,
                signals: signals
            };
        }
        
        function updateDisplay() {
            if (!computedData) {
                document.getElementById('resultContent').textContent = '请选择至少一个网络';
                document.getElementById('svgContent').innerHTML = '';
                document.getElementById('netLabels').innerHTML = '';
                return;
            }
            
            var freq = computedData.freq;
            var period = computedData.period;
            var setup = computedData.setup;
            var hold = computedData.hold;
            var dist = computedData.dist;
            var signals = computedData.signals;
            
            var resultTxt = '时钟: ' + freq.toFixed(1) + ' MHz | 周期: ' + period.toFixed(2) + ' ns\n';
            resultTxt += 'Tsu: ' + setup.toFixed(2) + ' ns | Th: ' + hold.toFixed(2) + ' ns\n';
            resultTxt += '--------------------------------------------\n';
            
            signals.forEach(function(sig, i) {
                var lenStr = sig.traceLen ? sig.traceLen.toFixed(0) + 'mil' : sig.dist.toFixed(0) + 'mil';
                var manhattanStr = sig.dist.toFixed(0) + 'mil';
                resultTxt += '[' + (i+1) + '] ' + sig.net + ': 曼哈顿距离=' + manhattanStr + ' | 实际长度=' + lenStr + ' | Tpd=' + sig.pd.toFixed(2) + 'ns, 余量=' + sig.margin.toFixed(2) + 'ns ' + (sig.margin > 0 ? '✓ PASS' : '✗ FAIL') + '\n';
            });
            
            document.getElementById('resultContent').textContent = resultTxt;
            
            renderNetLabels(signals);
            renderTimingHeader(componentData.des1, componentData.des2, signals.length, freq, period, setup, hold);
            
            var svg = makeMultiSignalSVG(
                componentData.des1, componentData.des2, 
                componentData.name1, componentData.name2,
                signals, freq, period, setup, hold, dist, false
            );
            
            document.getElementById('svgContent').innerHTML = svg;
            resetZoom();
            log('更新完成, ' + signals.length + '路信号');
        }
        
        function renderNetLabels(signals) {
            var netLabelsDiv = document.getElementById('netLabels');
            netLabelsDiv.innerHTML = '';
            
            var clkLabel = document.createElement('div');
            clkLabel.className = 'net-label';
            clkLabel.style.color = '#fcc';
            clkLabel.style.height = '60px';
            clkLabel.textContent = 'CLK';
            netLabelsDiv.appendChild(clkLabel);
            
            var colors = ['#0f8', '#0af', '#f0f', '#fa0', '#0fa'];
            
            signals.forEach(function(sig, i) {
                var color = colors[i % colors.length];
                
                var labelRow = document.createElement('div');
                labelRow.style.display = 'flex';
                labelRow.style.flexDirection = 'column';
                labelRow.style.justifyContent = 'center';
                labelRow.style.height = '60px';
                labelRow.style.paddingLeft = '8px';
                
                var labelOut = document.createElement('div');
                labelOut.className = 'net-label-name';
                labelOut.style.color = color;
                labelOut.style.fontSize = '10px';
                labelOut.style.fontFamily = 'Consolas, monospace';
                labelOut.textContent = sig.net;
                labelRow.appendChild(labelOut);
                
                var labelIn = document.createElement('div');
                labelIn.className = 'net-label-name';
                labelIn.style.color = color;
                labelIn.style.fontSize = '10px';
                labelIn.style.fontFamily = 'Consolas, monospace';
                labelIn.textContent = sig.net + '_IN';
                labelRow.appendChild(labelIn);
                
                netLabelsDiv.appendChild(labelRow);
            });
        }
        
        function renderTimingHeader(sd, td, signalCount, freq, period, su, th) {
            var headerDiv = document.getElementById('timingHeader');
            headerDiv.querySelector('.title').textContent = 'Timing: ' + sd + ' → ' + td + ' (' + signalCount + ' signals)';
            headerDiv.querySelector('.subtitle').textContent = freq.toFixed(1) + ' MHz | Period: ' + period.toFixed(2) + ' ns | Tsu: ' + su.toFixed(1) + 'ns | Th: ' + th.toFixed(1) + 'ns';
        }
        
        function makeMultiSignalSVG(sd, td, sn1, sn2, signals, freq, period, su, th, dist, includeExtras) {
            var signalCount = signals.length;
            var rowHeight = 60;
            var headerHeight = 60;
            var footerHeight = 120;
            
            var labelWidth = includeExtras ? 80 : 0;
            var signalStartX = includeExtras ? 100 : 20;
            var w = 700 + labelWidth;
            var h = headerHeight + signalCount * rowHeight + 60;
            var lm = signalStartX, rm = 180, aw = w - lm - rm, tp2 = period * 1.5, ts = aw / tp2;
            
            var s = '<svg width="' + w + '" height="' + h + '" xmlns="http://www.w3.org/2000/svg">';
            s += '<rect width="' + w + '" height="' + h + '" fill="#1e1e1e"/>';
            
            if (includeExtras) {
                s += '<rect x="0" y="0" width="' + labelWidth + '" height="' + h + '" fill="#2d2d2d"/>';
                s += '<rect x="0" y="0" width="' + w + '" height="' + headerHeight + '" fill="#2d2d2d"/>';
                s += '<rect x="0" y="' + (h - footerHeight) + '" width="' + w + '" height="' + footerHeight + '" fill="#252525"/>';
                s += '<line x1="0" y1="' + headerHeight + '" x2="' + w + '" y2="' + headerHeight + '" stroke="#444" stroke-width="1"/>';
                s += '<line x1="0" y1="' + (h - footerHeight) + '" x2="' + w + '" y2="' + (h - footerHeight) + '" stroke="#444" stroke-width="1"/>';
                s += '<line x1="' + labelWidth + '" y1="0" x2="' + labelWidth + '" y2="' + h + '" stroke="#444" stroke-width="1"/>';
                
                var labelX = 8;
                var labelY = 48;
                s += '<text x="' + labelX + '" y="' + labelY + '" fill="#fcc" font-family="Consolas,monospace" font-size="10" font-weight="bold">CLK</text>';
                
                var colors = ['#0f8', '#0af', '#f0f', '#fa0', '#0fa'];
                signals.forEach(function(sig, i) {
                    var color = colors[i % colors.length];
                    var rowY = headerHeight + i * rowHeight + 28;
                    var rowY2 = rowY + 18;
                    s += '<text x="' + labelX + '" y="' + rowY + '" fill="' + color + '" font-family="Consolas,monospace" font-size="10">' + sig.net + '</text>';
                    s += '<text x="' + labelX + '" y="' + rowY2 + '" fill="' + color + '" font-family="Consolas,monospace" font-size="9" opacity="0.7">' + sig.net + '_IN</text>';
                });
                
                var infoX = w - 160;
                var infoY = 20;
                s += '<text x="' + infoX + '" y="' + infoY + '" fill="#ffcc00" font-family="Consolas,monospace" font-size="11" font-weight="bold">Timing Summary</text>';
                s += '<line x1="' + infoX + '" y1="' + (infoY + 6) + '" x2="' + (infoX + 140) + '" y2="' + (infoY + 6) + '" stroke="#555"/>';
                s += '<text x="' + infoX + '" y="' + (infoY + 20) + '" fill="#fff" font-family="Consolas,monospace" font-size="10">Freq: ' + freq.toFixed(1) + ' MHz</text>';
                s += '<text x="' + infoX + '" y="' + (infoY + 34) + '" fill="#fff" font-family="Consolas,monospace" font-size="10">Period: ' + period.toFixed(2) + ' ns</text>';
                s += '<text x="' + infoX + '" y="' + (infoY + 48) + '" fill="#ff6666" font-family="Consolas,monospace" font-size="10">Tsu: ' + su.toFixed(2) + ' ns</text>';
                s += '<text x="' + infoX + '" y="' + (infoY + 62) + '" fill="#66ff66" font-family="Consolas,monospace" font-size="10">Th: ' + th.toFixed(2) + ' ns</text>';
            }
            
            var lx = lm, cx = lm + period * ts;
            var clkY = 40;
            var hp = period / 2 * ts;
            var indicatorY = 10;
            
            s += '<line x1="' + lm + '" y1="' + clkY + '" x2="' + (lm + hp) + '" y2="' + clkY + '" stroke="#fcc" stroke-width="2"/>';
            s += '<line x1="' + (lm + hp) + '" y1="' + clkY + '" x2="' + (lm + hp) + '" y2="' + (clkY - 20) + '" stroke="#fcc" stroke-width="2"/>';
            s += '<line x1="' + (lm + hp) + '" y1="' + (clkY - 20) + '" x2="' + (lm + period*ts) + '" y2="' + (clkY - 20) + '" stroke="#fcc" stroke-width="2"/>';
            s += '<line x1="' + (lm + period*ts) + '" y1="' + (clkY - 20) + '" x2="' + (lm + period*ts) + '" y2="' + clkY + '" stroke="#fcc" stroke-width="2"/>';
            var b1 = lm + period * ts;
            s += '<line x1="' + b1 + '" y1="' + clkY + '" x2="' + (b1 + hp) + '" y2="' + clkY + '" stroke="#fcc" stroke-width="2"/>';
            s += '<line x1="' + (b1 + hp) + '" y1="' + clkY + '" x2="' + (b1 + hp) + '" y2="' + (clkY - 20) + '" stroke="#fcc" stroke-width="2"/>';
            
            s += '<line x1="' + lx + '" y1="' + indicatorY + '" x2="' + lx + '" y2="' + (h - 40) + '" stroke="#0f8" stroke-width="1.5" stroke-dasharray="5,3"/>';
            s += '<text x="' + lx + '" y="' + (indicatorY + 5) + '" text-anchor="middle" fill="#0f8" font-family="Consolas,monospace" font-size="10" font-weight="bold">Launch</text>';
            s += '<line x1="' + cx + '" y1="' + indicatorY + '" x2="' + cx + '" y2="' + (h - 40) + '" stroke="#f66" stroke-width="1.5" stroke-dasharray="5,3"/>';
            s += '<text x="' + cx + '" y="' + (indicatorY + 5) + '" text-anchor="middle" fill="#f66" font-family="Consolas,monospace" font-size="10" font-weight="bold">Capture</text>';
            
            var colors = ['#0f8', '#0af', '#f0f', '#fa0', '#0fa'];
            signals.forEach(function(sig, i) {
                var dataY = headerHeight + i * rowHeight + 25;
                var color = colors[i % colors.length];
                var ox1 = lx + 0.3 * ts, ox2 = b1 + 0.3 * ts, ix1 = ox1 + sig.pd * ts, ix2 = ox2 + sig.pd * ts;
                
                s += '<line x1="' + lm + '" y1="' + dataY + '" x2="' + ox1 + '" y2="' + dataY + '" stroke="' + color + '" stroke-width="2"/>';
                s += '<line x1="' + ox1 + '" y1="' + dataY + '" x2="' + ox1 + '" y2="' + (dataY - 16) + '" stroke="' + color + '" stroke-width="2"/>';
                s += '<line x1="' + ox1 + '" y1="' + (dataY - 16) + '" x2="' + ox2 + '" y2="' + (dataY - 16) + '" stroke="' + color + '" stroke-width="2"/>';
                s += '<line x1="' + ox2 + '" y1="' + (dataY - 16) + '" x2="' + ox2 + '" y2="' + dataY + '" stroke="' + color + '" stroke-width="2"/>';
                s += '<line x1="' + ox2 + '" y1="' + dataY + '" x2="' + (lm + tp2*ts) + '" y2="' + dataY + '" stroke="' + color + '" stroke-width="2"/>';
                
                var dataInY = dataY + 25;
                s += '<line x1="' + lm + '" y1="' + dataInY + '" x2="' + ix1 + '" y2="' + dataInY + '" stroke="' + color + '" stroke-width="2"/>';
                s += '<line x1="' + ix1 + '" y1="' + dataInY + '" x2="' + ix1 + '" y2="' + (dataInY - 16) + '" stroke="' + color + '" stroke-width="2"/>';
                s += '<line x1="' + ix1 + '" y1="' + (dataInY - 16) + '" x2="' + ix2 + '" y2="' + (dataInY - 16) + '" stroke="' + color + '" stroke-width="2"/>';
                s += '<circle cx="' + cx + '" cy="' + (dataInY - 16) + '" r="4" fill="#f66" stroke="#fff" stroke-width="1"/>';
                s += '<line x1="' + ix2 + '" y1="' + (dataInY - 16) + '" x2="' + ix2 + '" y2="' + dataInY + '" stroke="' + color + '" stroke-width="2"/>';
                s += '<line x1="' + ix2 + '" y1="' + dataInY + '" x2="' + (lm + tp2*ts) + '" y2="' + dataInY + '" stroke="' + color + '" stroke-width="2"/>';
            });
            
            var lastSignalIdx = signals.length - 1;
            var lastDataInY = headerHeight + lastSignalIdx * rowHeight + 50;
            
            var setupWinX = cx - su * ts;
            var setupWinW = su * ts;
            var holdWinX = cx;
            var holdWinW = th * ts;
            var winBaseY = lastDataInY + 20;
            var winH = 18;
            
            s += '<rect x="' + setupWinX + '" y="' + (winBaseY - winH) + '" width="' + setupWinW + '" height="' + winH + '" fill="rgba(255, 200, 0, 0.25)" stroke="#ffc800" stroke-width="1" stroke-dasharray="3,2"/>';
            s += '<text x="' + (setupWinX + setupWinW/2) + '" y="' + (winBaseY - 4) + '" text-anchor="middle" fill="#ffc800" font-family="Consolas,monospace" font-size="8" font-weight="bold">Tsu ' + su.toFixed(1) + 'ns</text>';
            
            s += '<rect x="' + holdWinX + '" y="' + (winBaseY - winH) + '" width="' + holdWinW + '" height="' + winH + '" fill="rgba(0, 255, 136, 0.25)" stroke="#00ff88" stroke-width="1" stroke-dasharray="3,2"/>';
            s += '<text x="' + (holdWinX + holdWinW/2) + '" y="' + (winBaseY - 4) + '" text-anchor="middle" fill="#00ff88" font-family="Consolas,monospace" font-size="8" font-weight="bold">Th ' + th.toFixed(1) + 'ns</text>';
            
            s += '</svg>';
            return s;
        }
        
        function copyResult() {
            var text = document.getElementById('resultContent').textContent;
            navigator.clipboard.writeText(text).then(function() {
                log('结果已复制到剪贴板');
            }).catch(function() {
                log('复制失败');
            });
        }
        
        function closeForm() {
            highlightedNets.forEach(function(net) {
                try { eda.pcb_Net.unhighlightNet(net); } catch {}
            });
            highlightedNets = [];
            try { eda.sys_IFrame.closeIFrame('timingForm'); } catch {}
        }
        
        function exportSVG() {
            if (!computedData) {
                alert('没有可导出的数据');
                return;
            }
            var svg = makeMultiSignalSVG(
                componentData.des1, componentData.des2,
                componentData.name1, componentData.name2,
                computedData.signals, computedData.freq, computedData.period,
                computedData.setup, computedData.hold, computedData.dist, true
            );
            var blob = new Blob([svg], { type: 'image/svg+xml' });
            var fileName = 'timing_' + Date.now() + '.svg';
            eda.sys_FileSystem.saveFile(blob, fileName).then(function() {
                log('SVG导出成功: ' + fileName);
            }).catch(function(err) {
                log('SVG导出失败: ' + err);
                alert('导出失败: ' + err);
            });
        }
        
        document.getElementById('freqInput').addEventListener('input', function() {
            updatePeriod();
            computeTimingData();
        });
        document.getElementById('setupInput').addEventListener('input', function() {
            computeTimingData();
        });
        document.getElementById('holdInput').addEventListener('input', function() {
            computeTimingData();
        });
        document.getElementById('calcBtn').addEventListener('click', function() {
            autoUpdate = true;
            calculate();
        });
        
        document.getElementById('exportBtn').addEventListener('click', function() {
            exportSVG();
        });
        
        window.onbeforeunload = function() {
            highlightedNets.forEach(function(net) {
                try { eda.pcb_Net.unhighlightNet(net); } catch {}
            });
            highlightedNets = [];
        };
        
        log('页面加载');
        eda.sys_MessageBus.subscribePublic('timingFormData', function(data) {
            log('收到推送数据');
            if (data && data.info) initForm(data);
        });
        eda.sys_MessageBus.publishPublic('requestTimingFormData', null);
        
        setTimeout(function() { 
            if (!componentData) { 
                log('超时，再次请求'); 
                eda.sys_MessageBus.publishPublic('requestTimingFormData', null);
            } 
        }, 3000);
    </script>
</body>
</html>
